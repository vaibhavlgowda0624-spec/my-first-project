import tkinter as tk
from tkinter import messagebox
import re
import hashlib

# Password strength checker
def check_strength():
    password = entry.get()
    score = 0

    if len(password) >= 8:
        score += 1
    if re.search("[A-Z]", password):
        score += 1
    if re.search("[a-z]", password):
        score += 1
    if re.search("[0-9]", password):
        score += 1
    if re.search("[!@#$%^&*]", password):
        score += 1

    if score <= 2:
        result_label.config(text="Weak ❌", fg="red")
    elif score == 3 or score == 4:
        result_label.config(text="Medium ⚠️", fg="orange")
    else:
        result_label.config(text="Strong ✅", fg="green")

# Hash password
def hash_password():
    password = entry.get()
    hashed = hashlib.sha256(password.encode()).hexdigest()
    messagebox.showinfo("Hashed Password", hashed)

# Dictionary attack simulation
def dictionary_attack():
    password = entry.get()

    common_passwords = ["123456", "password", "admin", "qwerty", "letmein"]

    if password in common_passwords:
        messagebox.showwarning("Attack Result", "Password easily cracked ❌")
    else:
        messagebox.showinfo("Attack Result", "Password not in common list ✅")

# GUI
window = tk.Tk()
window.title("Password Security Tool 🔐")
window.geometry("400x300")

tk.Label(window, text="Enter Password:", font=("Arial", 12)).pack(pady=10)

entry = tk.Entry(window, width=30, show="*")
entry.pack(pady=5)

tk.Button(window, text="Check Strength", command=check_strength).pack(pady=5)
tk.Button(window, text="Hash Password", command=hash_password).pack(pady=5)
tk.Button(window, text="Simulate Attack", command=dictionary_attack).pack(pady=5)

result_label = tk.Label(window, text="", font=("Arial", 12))
result_label.pack(pady=10)

window.mainloop()
